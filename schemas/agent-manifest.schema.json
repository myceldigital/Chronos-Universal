{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chronos-universal.dev/schemas/agent-manifest.schema.json",
  "title": "AgentCapabilityManifest",
  "type": "object",
  "required": ["agent_id", "display_name", "capabilities", "constraints", "cron_compatibility"],
  "additionalProperties": false,
  "properties": {
    "agent_id": { "type": "string", "minLength": 1 },
    "display_name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "capabilities": {
      "type": "object",
      "required": ["read", "reason", "write", "act"],
      "additionalProperties": false,
      "properties": {
        "read": { "type": "array", "items": { "type": "string" } },
        "reason": { "type": "array", "items": { "type": "string" } },
        "write": { "type": "array", "items": { "type": "string" } },
        "act": { "type": "array", "items": { "type": "string" } }
      }
    },
    "constraints": {
      "type": "object",
      "required": ["max_risk_class", "requires_approval_for", "forbidden_actions"],
      "additionalProperties": false,
      "properties": {
        "max_risk_class": { "type": "string", "enum": ["L0", "L1", "L2", "L3", "L4", "L5"] },
        "requires_approval_for": { "type": "array", "items": { "type": "string" } },
        "forbidden_actions": { "type": "array", "items": { "type": "string" } }
      }
    },
    "cron_compatibility": {
      "type": "object",
      "required": ["can_run_scheduled", "preferred_frequencies", "max_runtime_seconds"],
      "additionalProperties": false,
      "properties": {
        "can_run_scheduled": { "type": "boolean" },
        "preferred_frequencies": {
          "type": "array",
          "items": { "type": "string", "enum": ["hourly", "daily", "weekly", "monthly", "event_triggered"] }
        },
        "max_runtime_seconds": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
